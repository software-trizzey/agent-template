{
	"name": "agent-template",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"lint": "bunx @biomejs/biome check .",
		"format": "bunx @biomejs/biome format .",
		"check": "bun run lint && bun run format",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:core": "bun test test/core",
		"test:contracts": "bun test test/contracts test/profiles",
		"test:evals": "bun test test/evals"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.66.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"cac": "^7.0.0",
		"zod": "^4.3.6"
	}
}
